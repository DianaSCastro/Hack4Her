{
  "manifest_version": 3,
  "name": "O-Trace — Agente IA",
  "version": "2.0.0",
  "description": "Agente de lectura y automatización web para Arca Continental.",

  "permissions": ["activeTab","scripting","storage","tabs"],

  "host_permissions": [
    "http://localhost:5000/*",
    "https://*/*",
    "http://*/*"
  ],

  "background": { "service_worker": "background.js" },

  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["overlay.css"],
    "run_at": "document_idle"
  }],

  

  "web_accessible_resources": [{
    "resources": ["icons/*"],
    "matches": ["<all_urls>"]
  }],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
